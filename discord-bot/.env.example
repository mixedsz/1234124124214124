# Discord Bot Token (from Discord Developer Portal → Your App → Bot → Token)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Discord Application Client ID (from Developer Portal → General Information)
DISCORD_CLIENT_ID=your_application_client_id_here

# Your Discord server (guild) ID — right-click server → Copy Server ID
DISCORD_GUILD_ID=your_guild_id_here

# Your website URL (no trailing slash)
SITE_URL=https://yourstore.com

# Must match REVIEWS_BOT_TOKEN set in Vercel environment variables
REVIEWS_BOT_TOKEN=some_long_random_secret_string

# Optional: channel ID to post review confirmations publicly
REVIEWS_CHANNEL_ID=
